/* user.wxss */

.container {
  padding: 16rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.user-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.user-details {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-tag {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  margin-top: 8rpx;
}

.tag-vip {
  background-color: #ff4d4f;
}

.tag-normal {
  background-color: rgba(255, 255, 255, 0.25);
}

.tag-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

.user-vip-detail {
  width: 100%;
  margin-top: 12rpx;
  padding-left: 120rpx;
}

.vip-expiry {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 绑定手机号 */
.bind-phone-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.bind-phone-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.bind-phone-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.bind-phone-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.bind-phone-desc {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
}

.bind-phone-form {
  width: 100%;
}

.code-form-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.code-input {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  background-color: #fafafa;
}

.code-input-small {
  flex: 1;
}

.code-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #1890ff;
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 8rpx;
  padding: 0;
  border: none;
  white-space: nowrap;
}

.code-btn[disabled] {
  background-color: #d9d9d9;
  color: #999999;
}

.bind-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 登录提示 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  width: 100%;
}

.login-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.login-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 40rpx;
  text-align: center;
}

.login-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wechat-login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #07c160;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.wechat-icon {
  font-size: 32rpx;
}

.login-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-top: 8rpx;
  width: 100%;
}

.login-hint {
  text-align: center;
  font-size: 22rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 退出登录 */
.logout-section {
  margin-top: 16rpx;
}

.logout-btn {
  background-color: #ffffff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
}

/* 功能菜单 */
.menu-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 24rpx;
  color: #cccccc;
}

/* 管理员功能 */
.admin-section {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 12rpx;
  padding: 0 24rpx;
}

/* VIP升级卡片 */
.vip-section {
  margin-top: 16rpx;
}

.vip-card {
  background: linear-gradient(135deg, #ff9a56 0%, #ff6348 100%);
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 99, 72, 0.3);
}

.vip-card-title {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.vip-card-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 24rpx;
}

.vip-card-btn {
  display: inline-block;
  background-color: #ffffff;
  color: #ff6348;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
  border: none;
}
