/* user.wxss */

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #1890ff;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.user-email {
  font-size: 20rpx;
  color: #666666;
}

.user-vip {
  background-color: #f6ffed;
  border-radius: 4rpx;
  padding: 8rpx 12rpx;
  margin-left: 16rpx;
}

.vip-text {
  font-size: 20rpx;
  color: #52c41a;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.vip-expiry {
  font-size: 18rpx;
  color: #8c8c8c;
}

/* 登录提示 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 48rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  width: 100%;
}

.login-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.login-text {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 24rpx;
}

.login-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-item {
  width: 100%;
}

.form-item input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #333333;
  background-color: #fafafa;
}

.form-item input:focus {
  border-color: #1890ff;
  background-color: #ffffff;
}

.login-btn {
  background-color: #1890ff;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 24rpx;
  margin-top: 16rpx;
  width: 100%;
}

.login-hint {
  text-align: center;
  font-size: 18rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 功能菜单 */
.menu-section {
  background-color: #ffffff;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 24rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 18rpx;
  color: #999999;
}

.menu-badge {
  position: absolute;
  top: 50%;
  right: 24rpx;
  transform: translateY(-50%);
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background-color: #ff4d4f;
  color: #ffffff;
  font-size: 16rpx;
  text-align: center;
  line-height: 32rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
}

/* 管理员功能 */
.admin-section {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 18rpx;
  color: #999999;
  margin-bottom: 12rpx;
  padding: 0 24rpx;
}

/* 用户信息显示 */
.user-info-section {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  padding: 12rpx 24rpx;
  align-items: center;
}

.info-label {
  font-size: 22rpx;
  color: #666666;
  width: 120rpx;
}

.info-value {
  flex: 1;
  font-size: 22rpx;
  color: #333333;
  text-align: right;
}

/* 退出登录按钮 */
.logout-btn {
  background-color: #ffffff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  border-radius: 4rpx;
  padding: 12rpx;
  font-size: 25rpx;
  margin-top: 24rpx;
}