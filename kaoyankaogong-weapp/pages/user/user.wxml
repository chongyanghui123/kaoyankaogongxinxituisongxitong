<!-- user.wxml -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-info" wx:if="{{userInfo}}">
    <view class="user-avatar">{{userInfo.username.charAt(0)}}</view>
    <view class="user-details">
      <view class="user-name">{{userInfo.username}}</view>
      <view class="user-email">{{userInfo.email}}</view>
    </view>
    <view class="user-vip" wx:if="{{userInfo.is_vip_active}}">
      <text class="vip-text">VIP会员</text>
      <text class="vip-expiry">有效期至: {{userInfo.vip_end_time}}</text>
    </view>
  </view>
  
  <!-- 未登录状态 -->
  <view class="login-prompt" wx:else>
    <view class="login-icon">🔐</view>
    <view class="login-text">请登录以使用更多功能</view>
    <view class="login-form">
      <view class="form-item">
        <input placeholder="请输入手机号" bindinput="bindPhoneInput" value="{{phone}}" />
      </view>
      <view class="form-item">
        <input placeholder="请输入密码" bindinput="bindPasswordInput" value="{{password}}" password />
      </view>
      <button class="login-btn" bindtap="login">登录</button>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="navigateToSubscription">
      <view class="menu-icon">💎</view>
      <view class="menu-text">订阅管理</view>
      <view class="menu-arrow">→</view>
    </view>
    <view class="menu-item" bindtap="navigateToMessage">
      <view class="menu-icon">📢</view>
      <view class="menu-text">消息中心</view>
      <view class="menu-arrow">→</view>
    </view>
    <view class="menu-item" bindtap="navigateToCollection">
      <view class="menu-icon">⭐</view>
      <view class="menu-text">我的收藏</view>
      <view class="menu-arrow">→</view>
    </view>
    <view class="menu-item" bindtap="navigateToSettings">
      <view class="menu-icon">⚙️</view>
      <view class="menu-text">设置</view>
      <view class="menu-arrow">→</view>
    </view>
  </view>

  <!-- 管理员入口 -->
  <view class="admin-section" wx:if="{{userInfo && userInfo.is_admin}}">
    <view class="section-title">管理员功能</view>
    <view class="menu-item" bindtap="navigateToAdmin">
      <view class="menu-icon">🛠️</view>
      <view class="menu-text">后台管理</view>
      <view class="menu-arrow">→</view>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <button class="logout-btn" wx:if="{{userInfo}}" bindtap="logout">退出登录</button>
</view>