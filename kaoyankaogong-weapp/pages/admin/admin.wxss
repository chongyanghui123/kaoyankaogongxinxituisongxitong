/* admin.wxss */

/* 管理员功能导航 */
.admin-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.nav-item {
  flex: 1 1 calc(50% - 8rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 24rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.nav-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.nav-text {
  font-size: 16rpx;
  color: #333333;
}

/* 系统概览 */
.overview-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 18rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.overview-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.overview-card {
  flex: 1 1 calc(50% - 8rpx);
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.card-content {
  flex: 1;
}

.card-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.card-label {
  font-size: 14rpx;
  color: #666666;
}

/* 手动触发推送 */
.push-section {
  margin-bottom: 24rpx;
}

.push-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.push-btn {
  background-color: #1890ff;
  color: #ffffff;
  border: none;
  border-radius: 4rpx;
  padding: 16rpx;
  font-size: 16rpx;
  font-weight: 500;
}