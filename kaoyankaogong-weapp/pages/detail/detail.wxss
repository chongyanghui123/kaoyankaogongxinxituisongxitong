/* detail.wxss */

/* 情报详情卡片 */
.detail-card {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.detail-title {
  font-size: 20rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 30rpx;
}

.detail-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.detail-type {
  font-size: 14rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.detail-time {
  font-size: 14rpx;
  color: #999999;
}

.detail-content {
  font-size: 16rpx;
  color: #333333;
  line-height: 28rpx;
  margin-bottom: 20rpx;
}

.detail-source {
  font-size: 14rpx;
  color: #999999;
  text-align: right;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-around;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-button {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 14rpx;
  color: #666666;
}

/* 相关情报 */
.related-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 18rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.related-list {
  background-color: #ffffff;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.related-item {
  padding: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.related-item:last-child {
  border-bottom: none;
}

.related-title {
  font-size: 16rpx;
  color: #333333;
  margin-bottom: 8rpx;
  line-height: 24rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.related-time {
  font-size: 12rpx;
  color: #999999;
}