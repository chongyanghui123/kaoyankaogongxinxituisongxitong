/* forgot-password.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 页面头部 */
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 40rpx;
}

.back-btn {
  font-size: 32rpx;
  color: #333;
  margin-right: 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

/* 表单区域 */
.form-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
  box-sizing: border-box;
  transition: border-color 0.3s;
}

.form-input:focus {
  border-color: #007aff;
}

.form-input::placeholder {
  color: #999;
}

/* 验证码输入区域 */
.code-input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.send-code-btn {
  width: 180rpx;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  line-height: 80rpx;
  text-align: center;
}

.send-code-btn.sendable {
  background-color: #007aff;
  color: #fff;
}

.send-code-btn.disabled {
  background-color: #f0f0f0;
  color: #999;
}

/* 密码显示/隐藏按钮 */
.toggle-password {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #999;
  cursor: pointer;
}

/* 确认按钮 */
.btn-section {
  padding: 0 40rpx;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 96rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

.confirm-btn.active {
  background-color: #007aff;
  color: #fff;
}

.confirm-btn.disabled {
  background-color: #f0f0f0;
  color: #999;
}

/* 提示信息 */
.tips-section {
  padding: 0 40rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

/* 响应式设计 */
@media screen and (max-width: 750rpx) {
  .container {
    padding: 16rpx;
  }

  .form-section {
    padding: 32rpx;
  }

  .form-item {
    margin-bottom: 32rpx;
  }

  .btn-section {
    padding: 0 32rpx;
  }

  .tips-section {
    padding: 0 32rpx;
  }
}
