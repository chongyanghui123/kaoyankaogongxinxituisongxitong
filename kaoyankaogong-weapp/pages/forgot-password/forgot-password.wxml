<!-- forgot-password.wxml -->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="navigateBack">←</view>
    <view class="page-title">找回密码</view>
  </view>

  <view class="form-section">
    <view class="form-item">
      <view class="form-label">手机号</view>
      <input 
        class="form-input" 
        placeholder="请输入手机号" 
        value="{{phone}}" 
        bindinput="bindPhoneInput"
        maxlength="11"
      />
    </view>

    <view class="form-item">
      <view class="form-label">验证码</view>
      <view class="code-input-wrapper">
        <input 
          class="form-input code-input" 
          placeholder="请输入验证码" 
          value="{{code}}" 
          bindinput="bindCodeInput"
          maxlength="6"
        />
        <button 
          class="send-code-btn {{canSendCode ? 'sendable' : 'disabled'}}" 
          bindtap="sendCode"
          disabled="{{!canSendCode}}"
        >
          {{codeBtnText}}
        </button>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">新密码</view>
      <input 
        class="form-input" 
        placeholder="请输入新密码（至少6位）" 
        value="{{newPassword}}" 
        bindinput="bindNewPasswordInput"
        password="{{!showNewPassword}}"
        maxlength="20"
      />
      <text class="toggle-password" bindtap="toggleShowNewPassword">
        {{showNewPassword ? '🙈' : '👁️'}}
      </text>
    </view>

    <view class="form-item">
      <view class="form-label">确认新密码</view>
      <input 
        class="form-input" 
        placeholder="请再次输入新密码" 
        value="{{confirmPassword}}" 
        bindinput="bindConfirmPasswordInput"
        password="{{!showConfirmPassword}}"
        maxlength="20"
      />
      <text class="toggle-password" bindtap="toggleShowConfirmPassword">
        {{showConfirmPassword ? '🙈' : '👁️'}}
      </text>
    </view>
  </view>

  <view class="btn-section">
    <button 
      class="confirm-btn {{canSubmit ? 'active' : 'disabled'}}" 
      bindtap="confirmResetPassword"
      disabled="{{!canSubmit}}"
    >
      确认重置密码
    </button>
  </view>

  <view class="tips-section">
    <view class="tip-item">• 密码长度至少6位</view>
    <view class="tip-item">• 密码包含字母、数字或特殊字符</view>
    <view class="tip-item">• 两次输入的密码必须一致</view>
  </view>
</view>
