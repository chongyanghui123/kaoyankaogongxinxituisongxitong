/* groups.wxss */

.container {
  padding: 0;
  padding-bottom: 100rpx;
  background-color: #f5f7fa;
}

/* 页面标题 */
.page-header {
  padding: 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 40rpx;
  padding: 12rpx 20rpx;
}

.search-icon {
  font-size: 24rpx;
  color: #999999;
  margin-right: 12rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  background: transparent;
}

.search-placeholder {
  color: #999999;
}

/* 区块样式 */
.section {
  margin-top: 20rpx;
  padding: 0 24rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #999999;
  font-weight: normal;
}

/* 热门小组列表 */
.group-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.group-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.group-item:last-child {
  border-bottom: none;
}

.group-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  margin-right: 20rpx;
}

.group-info {
  flex: 1;
}

.group-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.group-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #999999;
}

.group-action {
  margin-left: 20rpx;
}

.group-actions {
  display: flex;
  gap: 12rpx;
  margin-left: 20rpx;
}

.action-btn {
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.join-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.leave-btn {
  background-color: #f5f5f5;
  color: #999999;
}

.enter-btn {
  background-color: #ffffff;
  color: #667eea;
  border: 2rpx solid #667eea;
}

/* 推荐小组网格 */
.group-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.grid-group-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.grid-group-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.grid-group-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
  text-align: center;
}

.grid-group-members {
  font-size: 20rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.grid-group-actions {
  display: flex;
  gap: 8rpx;
  width: 100%;
}

.grid-action-btn {
  flex: 1;
  font-size: 20rpx;
  font-weight: 600;
  padding: 8rpx 12rpx;
  border-radius: 20rpx;
  border: none;
  text-align: center;
}

.grid-action-btn.join-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.grid-action-btn.leave-btn {
  background-color: #f5f5f5;
  color: #999999;
}

.grid-action-btn.enter-btn {
  background-color: #ffffff;
  color: #667eea;
  border: 1rpx solid #667eea;
}

/* 创建小组按钮 */
.create-group-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 64rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.create-icon {
  font-size: 32rpx;
  font-weight: bold;
}