<!-- qa.wxml -->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-title">问答板块</view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <input type="text" placeholder="搜索问题" placeholder-class="search-placeholder" />
    </view>
  </view>

  <!-- 问题分类 -->
  <view class="category-bar">
    <scroll-view scroll-x="true" class="category-scroll">
      <view class="category-item {{activeCategory === '全部' ? 'active' : ''}}" bindtap="switchCategory" data-category="全部">全部</view>
      <view class="category-item {{activeCategory === '考研' ? 'active' : ''}}" bindtap="switchCategory" data-category="考研">考研</view>
      <view class="category-item {{activeCategory === '公务员' ? 'active' : ''}}" bindtap="switchCategory" data-category="公务员">公务员</view>
      <view class="category-item {{activeCategory === '数学' ? 'active' : ''}}" bindtap="switchCategory" data-category="数学">数学</view>
      <view class="category-item {{activeCategory === '英语' ? 'active' : ''}}" bindtap="switchCategory" data-category="英语">英语</view>
      <view class="category-item {{activeCategory === '政治' ? 'active' : ''}}" bindtap="switchCategory" data-category="政治">政治</view>
      <view class="category-item {{activeCategory === '专业课' ? 'active' : ''}}" bindtap="switchCategory" data-category="专业课">专业课</view>
    </scroll-view>
  </view>

  <!-- 问题列表 -->
  <view class="question-list">
    <view wx:for="{{questions}}" wx:key="id" class="question-item" bindtap="navigateToQuestionDetail" data-id="{{item.id}}">
      <view class="question-content">
        <view class="question-title">{{item.title}}</view>
        <view class="question-desc">{{item.content}}</view>
      </view>
      <view class="question-stats">
        <view class="stat-item">
          <text class="stat-icon">👁️</text>
          <text class="stat-text">{{item.view_count}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-icon">💬</text>
          <text class="stat-text">{{item.answer_count}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-icon">👍</text>
          <text class="stat-text">{{item.like_count}}</text>
        </view>
      </view>
      <view class="question-footer">
        <view class="user-info">
          <view class="user-avatar">{{item.avatar}}</view>
          <view class="user-name">{{item.username || '匿名用户'}}</view>
        </view>
        <view class="question-time">{{item.created_at}}</view>
      </view>
    </view>
  </view>

  <!-- 提问按钮 -->
  <view class="ask-btn" bindtap="askQuestion">
    <text class="ask-icon">➕</text>
    <text>提问</text>
  </view>
</view>