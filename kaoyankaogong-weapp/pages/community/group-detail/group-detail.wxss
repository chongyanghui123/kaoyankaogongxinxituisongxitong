.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
  position: relative;
}

.join-tip-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.join-tip-content {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  width: 80%;
  max-width: 500rpx;
}

.tip-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.tip-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.tip-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.join-btn {
  width: 100%;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 25rpx;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 20rpx;
}

.message-item {
  margin-bottom: 30rpx;
}

.message-wrapper {
  display: flex;
  align-items: flex-start;
}

.message-wrapper.self {
  flex-direction: row-reverse;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.message-content {
  max-width: 500rpx;
  margin: 0 20rpx;
}

.sender-name {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.message-bubble {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  word-wrap: break-word;
  word-break: break-all;
}

.message-wrapper.self .message-bubble {
  background-color: #1890ff;
}

.message-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.message-wrapper.self .message-text {
  color: #fff;
}

.message-image {
  max-width: 400rpx;
  border-radius: 8rpx;
}

.system-message {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.message-time {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.message-wrapper.self .message-time {
  text-align: right;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.input-area {
  background-color: #fff;
  border-top: 1rpx solid #e5e5e5;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.message-input {
  flex: 1;
  height: 70rpx;
  background-color: #f5f7fa;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.image-btn {
  width: 70rpx;
  height: 70rpx;
  background-color: #f5f7fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.btn-icon {
  font-size: 40rpx;
}

.send-btn {
  width: 120rpx;
  height: 70rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.btn-text {
  font-size: 28rpx;
  font-weight: bold;
}

.at-btn {
  width: 70rpx;
  height: 70rpx;
  background-color: #1890ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.at-btn .btn-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.member-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.member-picker {
  width: 100%;
  background-color: #fff;
  border-radius: 30rpx 30rpx 0 0;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-close {
  font-size: 50rpx;
  color: #999;
  line-height: 1;
}

.member-list {
  max-height: 50vh;
  padding: 20rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  margin-bottom: 15rpx;
}

.member-item:active {
  background-color: #e6f7ff;
}

.member-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.member-name {
  font-size: 28rpx;
  color: #333;
}

.empty-members {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.mention {
  color: #1890ff;
  font-weight: bold;
}
