/* index.wxss */

.container {
  padding: 0;
  padding-bottom: 20rpx;
}

/* 轮播图样式 */
.banner-swiper {
  width: 100%;
  height: 360rpx;
  border-radius: 0;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
}

.banner-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.banner-empty {
  width: 100%;
  height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f7fa;
  color: #999999;
  font-size: 28rpx;
}

/* 签到卡片样式 */
.sign-in-card {
  margin: 20rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.sign-in-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.sign-in-title {
  display: flex;
  align-items: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.sign-in-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.sign-in-points {
  display: flex;
  align-items: baseline;
}

.points-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffd700;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

.sign-in-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sign-in-stats {
  display: flex;
  gap: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.sign-in-btn {
  background: linear-gradient(135deg, #ffd700 0%, #ffb700 100%);
  color: #333333;
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.sign-in-btn.signed {
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.8);
}

.sign-in-btn[disabled] {
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.8);
}

/* 未登录提示 */
.login-prompt {
  margin: 20rpx 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.login-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.login-text {
  font-size: 28rpx;
  color: #666666;
}

.login-arrow {
  font-size: 32rpx;
  color: #cccccc;
  margin-left: 16rpx;
}

/* 区块样式 */
.section {
  padding: 24rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

/* 互动社区网格 */
.community-grid {
  display: flex;
  gap: 20rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.community-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.community-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  color: #ffffff;
}

.community-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}
