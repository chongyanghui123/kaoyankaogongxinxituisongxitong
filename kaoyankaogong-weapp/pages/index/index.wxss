/* index.wxss */

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
  padding: 0 40rpx;
}

.placeholder-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.placeholder-hint {
  font-size: 22rpx;
  color: #999999;
}
