/* index.wxss */

/* 登录提示 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
  background-color: #f5f7fa;
  padding: 0 40rpx;
}

.login-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.login-text {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 40rpx;
  text-align: center;
}

.login-btn {
  width: 280rpx;
  height: 80rpx;
  background-color: #1890ff;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 40rpx;
}

.login-btn:hover {
  background-color: #40a9ff;
}

.login-btn:active {
  background-color: #096dd9;
}


/* 分类导航 */
.category-nav {
  display: flex;
  justify-content: space-around;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.category-text {
  font-size: 20rpx;
  color: #333333;
}

/* 搜索框 */
.search-input {
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 4rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
}

.search-input input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 22rpx;
  color: #333333;
}

.search-icon {
  font-size: 18rpx;
  color: #999999;
  margin-left: 8rpx;
}

/* 区块样式 */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 20rpx;
  color: #1890ff;
}

/* 情报列表 */
.info-list {
  background-color: #ffffff;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.info-item {
  padding: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-title {
  font-size: 24rpx;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 36rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.info-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-type {
  font-size: 18rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.info-time {
  font-size: 18rpx;
  color: #999999;
}