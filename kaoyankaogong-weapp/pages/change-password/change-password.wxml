<!-- change-password.wxml -->
<view class="container">
  <view class="header">
    <text class="title">修改密码</text>
  </view>
  
  <view class="form">
    <view class="form-item" wx:if="{{!isFirstLogin}}">
      <text class="label">旧密码</text>
      <view class="input-wrapper">
        <input 
          class="input" 
          password="{{!showOldPassword}}" 
          placeholder="请输入旧密码" 
          bindinput="bindOldPasswordInput"
        />
        <text class="toggle-password" bindtap="toggleShowOldPassword">
          {{showOldPassword ? '🙈' : '👁️'}}
        </text>
      </view>
    </view>
    
    <view class="form-item">
      <text class="label">新密码</text>
      <view class="input-wrapper">
        <input 
          class="input" 
          password="{{!showNewPassword}}" 
          placeholder="请输入新密码" 
          bindinput="bindNewPasswordInput"
        />
        <text class="toggle-password" bindtap="toggleShowNewPassword">
          {{showNewPassword ? '🙈' : '👁️'}}
        </text>
      </view>
    </view>
    
    <view class="form-item">
      <text class="label">确认新密码</text>
      <view class="input-wrapper">
        <input 
          class="input" 
          password="{{!showConfirmPassword}}" 
          placeholder="请确认新密码" 
          bindinput="bindConfirmPasswordInput"
        />
        <text class="toggle-password" bindtap="toggleShowConfirmPassword">
          {{showConfirmPassword ? '🙈' : '👁️'}}
        </text>
      </view>
    </view>
    
    <button class="submit-btn" bindtap="changePassword">确认修改</button>
  </view>
</view>