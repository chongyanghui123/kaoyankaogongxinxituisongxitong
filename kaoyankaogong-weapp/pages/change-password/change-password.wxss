/* change-password.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.form {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.input-wrapper {
  position: relative;
  width: 100%;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 0 80rpx 0 20rpx;
  font-size: 24rpx;
  color: #333;
  box-sizing: border-box;
}

.input:focus {
  border-color: #007aff;
  outline: none;
}

.toggle-password {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #999;
  cursor: pointer;
}

.toggle-password:active {
  color: #666;
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  background-color: #007aff;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  border-radius: 40rpx;
  margin-top: 40rpx;
  margin-bottom: 20rpx;
}

.submit-btn:hover {
  background-color: #0066cc;
}

.submit-btn:active {
  background-color: #0052a3;
}