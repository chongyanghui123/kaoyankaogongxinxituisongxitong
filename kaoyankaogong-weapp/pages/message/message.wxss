/* message.wxss */

/* 未登录提示 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.prompt-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.prompt-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.prompt-hint {
  font-size: 22rpx;
  color: #999999;
}

/* 消息分类标签 */
.message-tabs {
  display: flex;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 20rpx;
  color: #666666;
  border-bottom: 2rpx solid transparent;
}

.tab-item[data-selected="true"] {
  color: #1890ff;
  border-bottom-color: #1890ff;
  font-weight: 500;
}

/* 消息列表 */
.message-list {
  background-color: #ffffff;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.message-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.message-main {
  flex: 1;
  display: flex;
  align-items: flex-start;
  min-width: 0;
}

.message-action {
  margin-left: 16rpx;
}

.delete-btn {
  font-size: 20rpx;
  color: #ff4d4f;
  background-color: transparent;
  border: 1rpx solid #ff4d4f;
  border-radius: 4rpx;
  padding: 8rpx 12rpx;
  min-width: auto;
  height: auto;
  line-height: 1.2;
}

.delete-btn:active {
  background-color: #fff1f0;
}

.message-item:last-child {
  border-bottom: none;
}

.message-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.message-content {
  flex: 1;
  min-width: 0;
}

.message-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 36rpx;
}

.message-text {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 16rpx;
  line-height: 32rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.message-time {
  font-size: 18rpx;
  color: #999999;
}

.message-badge {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
  margin-left: 12rpx;
  margin-top: 8rpx;
  font-size: 12rpx;
  color: #ff4d4f;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0;
  background-color: #ffffff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 20rpx;
  color: #999999;
}

/* 加载更多 */
.loading {
  text-align: center;
  padding: 32rpx;
  color: #999999;
  font-size: 18rpx;
  background-color: #ffffff;
  border-radius: 8rpx;
  margin-top: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}