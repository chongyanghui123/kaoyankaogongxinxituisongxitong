/* pages/collection/collection.wxss */
.container {
  background-color: #f5f7fa;
  min-height: 100vh;
}

/* 导航栏 */
.nav-bar {
  padding: 30rpx 40rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e7eb;
  text-align: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

/* 内容区域 */
.content {
  padding: 30rpx 40rpx;
}

/* 收藏列表 */
.collection-list {
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
}

.collection-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s;
}

.collection-item:last-child {
  border-bottom: none;
}

.collection-item:active {
  background-color: #f9fafb;
}

/* 收藏项内容 */
.item-content {
  flex: 1;
}

.item-title {
  font-size: 32rpx;
  color: #1f2937;
  line-height: 1.4;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.item-date {
  font-size: 24rpx;
  color: #9ca3af;
}

.item-tag {
  padding: 4rpx 12rpx;
  background-color: #e0f2fe;
  color: #0369a1;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* 操作按钮 */
.item-actions {
  margin-left: 20rpx;
}

.delete-btn {
  padding: 10rpx 20rpx;
  background-color: #dc2626;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 1.2;
}

/* 学习资料详情 */
.material-detail {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: #ffffff;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #e5e7eb;
  position: sticky;
  top: 0;
  background-color: #ffffff;
  z-index: 10;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}

.detail-close {
  font-size: 40rpx;
  color: #6b7280;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f3f4f6;
}

.detail-content {
  padding: 30rpx 40rpx;
}

.material-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
  flex-wrap: wrap;
}

.material-type {
  padding: 8rpx 16rpx;
  background-color: #fee2e2;
  color: #dc2626;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.material-category {
  padding: 8rpx 16rpx;
  background-color: #dbeafe;
  color: #2563eb;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.material-subject {
  padding: 8rpx 16rpx;
  background-color: #f3f4f6;
  color: #6b7280;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.material-description {
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.material-info {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.file-size {
  color: #6b7280;
  font-size: 26rpx;
}

.download-count {
  color: #6b7280;
  font-size: 26rpx;
}

.material-rating {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.material-rating .star {
  color: #fbbf24;
  font-size: 24rpx;
  margin-right: 5rpx;
}

.rating-text {
  color: #6b7280;
  font-size: 26rpx;
  margin-left: 10rpx;
}

.material-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.download-btn {
  flex: 1;
  padding: 25rpx;
  background-color: #2563eb;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.rate-btn {
  flex: 1;
  padding: 25rpx;
  background-color: #10b981;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.favorite-btn {
  flex: 1;
  padding: 25rpx;
  background-color: #f59e0b;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.favorite-btn.active {
  background-color: #7c3aed;
}

.comment-btn {
  flex: 1;
  padding: 25rpx;
  background-color: #6b7280;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #6b7280;
  font-size: 28rpx;
}

/* 没有更多数据 */
.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #9ca3af;
  font-size: 24rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1.4;
}