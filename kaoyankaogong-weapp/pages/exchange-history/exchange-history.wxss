.history-container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.gift-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}

.history-info {
  flex: 1;
  margin-left: 20rpx;
}

.gift-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.history-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.points-used {
  font-size: 26rpx;
  color: #ff6b6b;
  margin-right: 16rpx;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.status-0 {
  background-color: #fff3e0;
  color: #ff9800;
}

.status-1 {
  background-color: #e3f2fd;
  color: #2196f3;
}

.status-2 {
  background-color: #e8f5e9;
  color: #4caf50;
}

.status-3 {
  background-color: #fafafa;
  color: #999999;
}

.history-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.tracking {
  font-size: 22rpx;
  color: #666666;
  margin-top: 8rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: #999999;
}
