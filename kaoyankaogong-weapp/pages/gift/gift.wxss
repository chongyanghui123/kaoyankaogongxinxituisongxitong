.gift-container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.points-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffd700;
  margin-top: 8rpx;
}

.points-action {
  display: flex;
  align-items: center;
  color: #ffffff;
  font-size: 26rpx;
}

.points-action .arrow {
  margin-left: 8rpx;
  font-size: 32rpx;
}

.gift-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.gift-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.gift-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}

.gift-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 160rpx;
}

.gift-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.gift-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.gift-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.gift-points {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.points-icon {
  margin-right: 4rpx;
}

.gift-stock {
  font-size: 22rpx;
  color: #999999;
}

.exchange-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  border: none;
  margin-left: 16rpx;
}

.exchange-btn[disabled] {
  background: #cccccc;
  color: #ffffff;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: #999999;
}
