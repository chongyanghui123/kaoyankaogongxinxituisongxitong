/* edit-requirements.wxss */
.container {
  flex: 1;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333333;
}

.page-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-right: 44rpx;
}

/* 需求信息表单 */
.requirements-form {
  margin-top: 16rpx;
}

.form-section {
  background-color: #ffffff;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  padding: 0 24rpx;
}

.form-item {
  display: flex;
  padding: 16rpx 24rpx;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 22rpx;
  color: #666666;
  width: 140rpx;
}

.input-box {
  flex: 1;
}

.input {
  font-size: 22rpx;
  color: #333333;
  width: 100%;
  padding: 8rpx 0;
}

/* 保存按钮 */
.save-section {
  padding: 40rpx 24rpx;
}

.save-btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  background-color: #409eff;
  color: #ffffff;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn:active {
  background-color: #66b1ff;
}

/* 加载状态 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #999999;
}
