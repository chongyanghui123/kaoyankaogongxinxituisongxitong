/* info.wxss */

/* 筛选条件 */
.filter {
  display: flex;
  background-color: #ffffff;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-right: 1rpx solid #f0f0f0;
}

.filter-item:last-child {
  border-right: none;
}

.filter-label {
  font-size: 20rpx;
  color: #666666;
  margin-right: 8rpx;
}

.filter-value {
  font-size: 20rpx;
  color: #333333;
  margin-right: 4rpx;
}

.filter-arrow {
  font-size: 18rpx;
  color: #999999;
}

/* 情报列表 */
.info-list {
  background-color: #ffffff;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.info-item {
  padding: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 36rpx;
}

.info-content {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 20rpx;
  line-height: 32rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.info-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-type {
  font-size: 18rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.info-time {
  font-size: 18rpx;
  color: #999999;
}

/* 加载更多 */
.load-more {
  margin-bottom: 16rpx;
}

.loading {
  text-align: center;
  padding: 32rpx;
  color: #999999;
  font-size: 18rpx;
  background-color: #ffffff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 选择器 */
.picker-view {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 999;
}

.picker-item {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 20rpx;
  color: #333333;
}