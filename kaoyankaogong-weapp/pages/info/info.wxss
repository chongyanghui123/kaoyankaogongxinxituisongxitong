/* info.wxss */

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
}

.search-input-el {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
}

.search-icon {
  font-size: 24rpx;
  color: #999999;
  margin-left: 12rpx;
}

/* 未登录提示横幅 */
.login-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.banner-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.banner-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.banner-title {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.banner-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.banner-btn {
  background-color: #ffffff;
  color: #1890ff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  white-space: nowrap;
}

/* 数据概览 */
.data-overview {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx 0;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1890ff;
  margin-bottom: 4rpx;
}

.overview-label {
  font-size: 20rpx;
  color: #999999;
}

.overview-divider {
  width: 1rpx;
  height: 48rpx;
  background-color: #f0f0f0;
}

/* 标签切换 */
.tab-bar {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666666;
  position: relative;
}

.tab-active {
  color: #1890ff;
  font-weight: 600;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #1890ff;
  border-radius: 2rpx;
}

/* 筛选条件 */
.filter {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-right: 1rpx solid #f0f0f0;
  font-size: 24rpx;
  color: #666666;
}

.filter-item:last-child {
  border-right: none;
}

.filter-active {
  color: #1890ff;
  font-weight: 600;
}

.filter-label {
  font-size: 20rpx;
  color: #666666;
  margin-right: 8rpx;
}

.filter-value {
  font-size: 20rpx;
  color: #333333;
  margin-right: 4rpx;
}

.filter-arrow {
  font-size: 18rpx;
  color: #999999;
}

/* 情报列表 */
.info-list {
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.info-item {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  align-items: flex-start;
}

.info-main {
  flex: 1;
  min-width: 0;
}

.info-actions {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
  padding-top: 8rpx;
}

.fav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 12rpx;
}

.fav-icon {
  font-size: 32rpx;
  color: #d9d9d9;
}

.fav-active .fav-icon {
  color: #faad14;
}

.fav-count {
  font-size: 18rpx;
  color: #999999;
  margin-top: 4rpx;
}

.info-item:last-child {
  border-bottom: none;
}

.info-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
  line-height: 40rpx;
}

.info-content {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 16rpx;
  line-height: 32rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.info-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-type {
  font-size: 18rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.type-kaoyan {
  color: #1890ff;
  background-color: #e6f7ff;
}

.type-kaogong {
  color: #52c41a;
  background-color: #f6ffed;
}

.info-province {
  font-size: 18rpx;
  color: #fa8c16;
  background-color: #fff7e6;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.info-school {
  font-size: 18rpx;
  color: #722ed1;
  background-color: #f9f0ff;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.info-time {
  font-size: 18rpx;
  color: #999999;
  margin-left: auto;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 24rpx;
}

/* 加载更多 */
.load-more {
  margin-bottom: 16rpx;
}

.loading {
  text-align: center;
  padding: 32rpx;
  color: #999999;
  font-size: 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 选择器 */
.picker-view {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 999;
}

.picker-item {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 24rpx;
  color: #333333;
}
