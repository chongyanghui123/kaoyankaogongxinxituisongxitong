/* pages/learning-materials/learning-materials.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.search-filter {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.search-bar {
  display: flex;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e6e6e6;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
}

.search-btn {
  width: 160rpx;
  height: 80rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 40rpx;
  margin-left: 20rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-bar {
  display: flex;
  justify-content: space-between;
}

.filter-picker {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e6e6e6;
  border-radius: 40rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.filter-picker:last-child {
  margin-right: 0;
}

.picker-text {
  font-size: 32rpx;
  color: #333;
}

.materials-list {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.material-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.material-item:last-child {
  border-bottom: none;
}

.material-cover {
  width: 200rpx;
  height: 150rpx;
  border-radius: 10rpx;
  overflow: hidden;
  margin-right: 20rpx;
}

.material-cover image {
  width: 100%;
  height: 100%;
}

.material-cover.placeholder {
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-icon {
  font-size: 60rpx;
}

.material-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.material-title {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
  color: #333;
  line-height: 1.4;
}

.material-meta {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  color: #666;
}

.material-type {
  margin-right: 20rpx;
}

.material-category {
  margin-right: 20rpx;
}

.material-subject {
  margin-right: 20rpx;
}

.vip-tag {
  background-color: #ff4d4f;
  color: #fff;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  font-weight: 500;
}

.material-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.material-size {
  margin-right: 20rpx;
}

.material-downloads {
  margin-right: 20rpx;
}

.material-rating {
  color: #666;
  margin-right: 20rpx;
}

.material-actions {
  display: flex;
  margin-top: auto;
}

.download-btn {
  flex: 1;
  height: 60rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  margin-right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rate-btn {
  flex: 1;
  height: 60rpx;
  background-color: #52c41a;
  color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  margin-left: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-btn {
  flex: 1;
  height: 60rpx;
  background-color: #fa8c16;
  color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  margin-left: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-btn.active {
  background-color: #ff4d4f;
  color: #fff;
}

.empty-state {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 100rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

.loading-state {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 100rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.loading-text {
  font-size: 32rpx;
  color: #999;
}

.history-btn {
  width: 100%;
  height: 80rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.detail-dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 90%;
  max-height: 80%;
  background-color: #fff;
  border-radius: 20rpx;
  z-index: 1001;
  overflow: scroll;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.detail-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.detail-body {
  padding: 30rpx;
}

.detail-cover {
  width: 100%;
  height: 300rpx;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.detail-cover image {
  width: 100%;
  height: 100%;
}

.detail-info {
  margin-bottom: 30rpx;
}

.detail-meta {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.detail-type {
  margin-right: 20rpx;
}

.detail-category {
  margin-right: 20rpx;
}

.detail-subject {
  margin-right: 20rpx;
}

.detail-stats {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.detail-size {
  margin-right: 20rpx;
}

.detail-downloads {
  margin-right: 20rpx;
}

.detail-rating {
  color: #666;
  margin-right: 20rpx;
}

.detail-description {
  margin-bottom: 30rpx;
}

.description-label {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.description-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.detail-actions {
  display: flex;
  margin-bottom: 30rpx;
}

.comment-btn {
  flex: 1;
  height: 60rpx;
  background-color: #faad14;
  color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  margin-left: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.comments-section {
  margin-top: 30rpx;
}

.comments-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.comments-list {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.comment-item {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.comment-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.comment-user {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.comment-actions {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.reply-btn {
  font-size: 24rpx;
  color: #1890ff;
}

.delete-btn {
  color: #dc2626;
  font-size: 24rpx;
  margin-left: auto;
}

.replies-list {
  margin-left: 40rpx;
  margin-top: 10rpx;
}

.comment-item {
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.no-comments {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background-color: #fff;
  border-radius: 20rpx;
  z-index: 1001;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.dialog-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.dialog-body {
  padding: 30rpx;
}

.rating-container {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 40rpx 0;
}

.rating-container .star {
  font-size: 60rpx;
  margin: 0 10rpx;
  color: #ccc;
}

.rating-container .star.active {
  color: #ffd700;
}

.rating-container .star.half {
  color: #ffb700;
}

.rating-display {
  font-size: 36rpx;
  color: #333;
  margin-left: 20rpx;
  font-weight: 500;
}

.rating-value {
  font-size: 24rpx;
  color: #666;
  margin-left: 10rpx;
}

.comment-textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #e6e6e6;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 32rpx;
  resize: none;
}

.dialog-footer {
  display: flex;
  padding: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.cancel-btn {
  flex: 1;
  height: 60rpx;
  background-color: #f0f0f0;
  color: #333;
  border-radius: 30rpx;
  font-size: 32rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-btn {
  flex: 1;
  height: 60rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 30rpx;
  font-size: 32rpx;
  margin-left: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
