/* app.wxss */

/* 全局样式 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: 16px;
  color: #333333;
}

/* 容器样式 */
.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  padding: 20rpx;
  margin-bottom: 20rpx;
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333333;
}

/* 副标题样式 */
.subtitle {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

/* 文本样式 */
.text {
  font-size: 24rpx;
  color: #666666;
  line-height: 40rpx;
}

/* 按钮样式 */
.btn {
  display: inline-block;
  padding: 20rpx 40rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
  cursor: pointer;
}

.btn-primary {
  background-color: #1890ff;
  color: #ffffff;
}

.btn-default {
  background-color: #f0f0f0;
  color: #333333;
}

/* 列表样式 */
.list {
  background-color: #ffffff;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

/* 分割线 */
.divider {
  height: 8rpx;
  background-color: #f5f7fa;
}

/* 加载更多 */
.loading {
  text-align: center;
  padding: 32rpx;
  color: #999999;
  font-size: 18rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 64rpx 0;
  color: #999999;
}

/* 搜索框 */
.search-input {
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 4rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
}

.search-input input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 20rpx;
  color: #333333;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 16rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-primary {
  background-color: #e6f7ff;
  color: #1890ff;
}

.tag-success {
  background-color: #f6ffed;
  color: #52c41a;
}

.tag-warning {
  background-color: #fff7e6;
  color: #fa8c16;
}

/* 消息提示 */
.message {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}

.message-success {
  background-color: #f6ffed;
  color: #52c41a;
}

.message-error {
  background-color: #fff2f0;
  color: #ff4d4f;
}

.message-warning {
  background-color: #fff7e6;
  color: #fa8c16;
}

/* 表格样式 */
.table {
  width: 100%;
  border-collapse: collapse;
  background-color: #ffffff;
  border-radius: 8rpx;
  overflow: hidden;
}

.table th,
.table td {
  padding: 12rpx;
  text-align: left;
  border-bottom: 1rpx solid #f0f0f0;
}

.table th {
  background-color: #fafafa;
  font-weight: 600;
  color: #333333;
}

/* 加载动画 */
.loading-spinner {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx;
}

/* 图片样式 */
.image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 头像样式 */
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
}

/* 徽章样式 */
.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background-color: #ff4d4f;
  color: #ffffff;
  font-size: 16rpx;
  text-align: center;
  line-height: 32rpx;
  padding: 0 12rpx;
}