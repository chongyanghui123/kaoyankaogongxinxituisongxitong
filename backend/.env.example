# 基本配置
ENVIRONMENT=development
DEBUG=True
PORT=8000
HOST=0.0.0.0
SECRET_KEY=your-secret-key-here-change-in-production
API_V1_STR=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# 数据库配置
DATABASE_USER=root
DATABASE_PASSWORD=your_password
DATABASE_HOST=your_server_ip
DATABASE_PORT=3306
COMMON_DB=common_db
KAOYAN_DB=kaoyan_db
KAOGONG_DB=kaogong_db

# Redis配置
REDIS_URL=redis://localhost:6379/0

# RabbitMQ配置（Celery）
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# 邮箱配置
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=your-email@qq.com

# 微信配置（小程序登录用）
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_TOKEN=
WECHAT_AES_KEY=

# 支付宝配置
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 微信支付配置
WXPAY_APP_ID=
WXPAY_MCH_ID=
WXPAY_API_KEY=
WXPAY_NOTIFY_URL=

# 爬虫配置
CRAWLER_INTERVAL=10
MAX_CONCURRENT_CRAWLERS=5
CRAWLER_TIMEOUT=30
CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# 推送配置
PUSH_ENABLED=True
PUSH_INTERVAL=5

# 会员配置
TRIAL_DAYS=3

# 文件上传配置
UPLOAD_PATH=static/uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# 阿里云OSS配置（文件存储）
OSS_ENABLED=true
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_REGION=cn-hangzhou
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# 日志配置
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=10

# 安全性配置
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# API限制配置
RATE_LIMIT_ENABLED=True
RATE_LIMIT=100/minute

# 数据库配置扩展
DATABASE_NAME_PREFIX=

# 缓存配置
CACHE_ENABLED=True
CACHE_TTL=1800

# 爬虫配置扩展
CRAWLER_RETRY_TIMES=3
